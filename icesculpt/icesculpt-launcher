#!/usr/bin/env python3
"""IceSculpt launcher."""

import sys
import os

# If running inside an AppImage, APPDIR will be set
appdir = os.environ.get('APPDIR')
if appdir:
    # Bundle path
    site_packages = os.path.join(appdir, 'usr', 'lib', 'python3.10', 'site-packages')
    if site_packages not in sys.path:
        sys.path.insert(0, site_packages)
else:
    # Local development: add parent of 'icesculpt' package to path
    # Assuming this script is in project_root/icesculpt/icesculpt-launcher
    # or project_root/usr/bin/icesculpt
    root = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    if root not in sys.path:
        sys.path.insert(0, root)

try:
    from icesculpt.app import main
except ImportError as e:
    print(f"Error: Could not import icesculpt.app: {e}", file=sys.stderr)
    print(f"sys.path: {sys.path}", file=sys.stderr)
    sys.exit(1)

if __name__ == "__main__":
    sys.exit(main())
